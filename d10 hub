local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "d10 Hub",
   Icon = 0,
   LoadingTitle = "Carregando...",
   LoadingSubtitle = "by d10",
   Theme = "Default",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "d10HubData",
      FileName = "config"
   },
   KeySystem = false
})

local maintab = Window:CreateTab("MainTab", 4483362458)

-- Variáveis de controle para os loops
local tokenRunning = false
local yenRunning = false

-- Referência do Remote (centralizada para evitar repetição)
local remotePath = game:GetService("ReplicatedStorage")
    :WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")
    :WaitForChild("Services")
    :WaitForChild("SeasonService")
    :WaitForChild("RF")
    :WaitForChild("RequestRankedReward")

-- Toggle para Token (Argumento 1)
local tokenToggle = maintab:CreateToggle({
   Name = "Auto Token",
   CurrentValue = false,
   Flag = "TokenFlag",
   Callback = function(Value)
      tokenRunning = Value
      if tokenRunning then
         task.spawn(function()
            while tokenRunning do
               pcall(function()
                  remotePath:InvokeServer(1)
               end)
               task.wait(1) -- Intervalo de 1 segundo
            end
         end)
      end
   end,
})

-- Toggle para Yen (Argumento 2)
local yenToggle = maintab:CreateToggle({
   Name = "Auto Yen",
   CurrentValue = false,
   Flag = "YenFlag",
   Callback = function(Value)
      yenRunning = Value
      if yenRunning then
         task.spawn(function()
            while yenRunning do
               pcall(function()
                  remotePath:InvokeServer(2)
               end)
               task.wait(1) -- Intervalo de 1 segundo
            end
         end)
      end
   end,
})
