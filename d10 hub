local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()

-- Alvo comum: Aumentar o tamanho do braço/mão para alcançar a bola de longe
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            if Character:FindFirstChild("RightHand") then
                -- Modifica o tamanho da mão localmente para um valor absurdo
                Character.RightHand.Size = Vector3.new(10, 10, 10)
                Character.RightHand.CanCollide = false
            end
        end)
    end
end)
